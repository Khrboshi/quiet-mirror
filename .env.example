# .env.example
# Copy these into Vercel → Project → Settings → Environment Variables
# All values are required unless marked optional.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Site URL ──────────────────────────────────────────────────────────────────
# Production domain — no trailing slash.
# Used for magic-link redirects, Dodo checkout return URLs, and cron routes.
NEXT_PUBLIC_SITE_URL=https://quietmirror.me

# ── AI — Groq ─────────────────────────────────────────────────────────────────
# Required for AI reflections and weekly summaries.
# The code reads GROQAPIKEY first, then falls back to GROQ_API_KEY.
# Set GROQAPIKEY to be safe.
GROQAPIKEY=YOUR_GROQ_API_KEY

# Groq model (optional — defaults to llama-4-scout-17b-16e-instruct)
GROQMODEL=llama-4-scout-17b-16e-instruct

# ── Dodo Payments (payment processor — new subscribers) ──────────────────────
# Get these from: Dodo dashboard → Developer → API Keys / Webhooks
#
# DODO_PAYMENTS_ENVIRONMENT must be "test_mode" for testing, "live_mode" for live.
DODO_PAYMENTS_API_KEY=YOUR_DODO_API_KEY
DODO_PAYMENTS_WEBHOOK_KEY=whsec_YOUR_DODO_WEBHOOK_SECRET
DODO_PAYMENTS_ENVIRONMENT=live_mode
DODO_PAYMENTS_PRODUCT_ID=pdt_YOUR_DODO_PRODUCT_ID

# ── Stripe (legacy — existing subscribers only — DO NOT REMOVE) ───────────────
# The Stripe webhook route must keep running until all pre-migration
# Stripe subscribers have cancelled or their subscriptions have expired.
# New subscribers use Dodo Payments. Do not remove these vars until confirmed safe.
STRIPE_PORTAL_RETURN_URL=https://quietmirror.me/settings/billing
STRIPE_PRICE_ID=price_YOUR_STRIPE_PRICE_ID
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# ── Email — Resend ────────────────────────────────────────────────────────────
# Required for newsletter confirmation emails.
# Create a free account at resend.com and verify your sending domain.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# ── Cron job protection ───────────────────────────────────────────────────────
# Required for /api/cron/weekly-summaries.
# Set to any long random string — must match the GitHub Actions secret CRON_SECRET.
CRON_SECRET=YOUR_LONG_RANDOM_CRON_SECRET

# ── Credits admin endpoint ────────────────────────────────────────────────────
# Required if you use /api/user/credits/add.
CREDITS_ADMIN_KEY=YOUR_LONG_RANDOM_SECRET
