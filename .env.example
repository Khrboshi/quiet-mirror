# .env.example
# Copy these into Vercel → Project → Settings → Environment Variables

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Site URL (required for magic-link + redirects)
# Use your production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://havenly.app

# AI — Groq (required for reflections and weekly summary)
# The code reads GROQAPIKEY first, then falls back to GROQ_API_KEY.
# Set GROQAPIKEY to be safe.
GROQAPIKEY=YOUR_GROQ_API_KEY

# Groq model (optional — defaults to llama-4-scout-17b-8e-instruct)
# The code reads GROQMODEL (no underscore). Set this if you want to override.
GROQMODEL=llama-4-scout-17b-8e-instruct

# Stripe (required for Premium billing)
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PRICE_ID=price_YOUR_STRIPE_PRICE_ID
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Email — Resend (required for newsletter confirmation emails)
# Create a free account at resend.com and verify your sending domain.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# Credits admin endpoint protection (required if you use /api/user/credits/add)
CREDITS_ADMIN_KEY=YOUR_LONG_RANDOM_SECRET
